# council — example environment. Copy to `.env` and fill in.

# === Required for embedding ===
# OpenAI API key. Used by app/embeddings/providers.py for the
# text-embedding-3-small endpoint (1536-dim, $0.02 per 1M tokens —
# a 5,000-chunk archive embeds for well under a dollar).
# Generate at https://platform.openai.com/api-keys.
OPENAI_API_KEY=

# === Optional: Twitter source ===
# TwitterAPI.io key (https://twitterapi.io). Required only if any
# mentor in config/mentors.yaml has a `twitter` source.
# Pricing: ~$0.15 per 1,000 tweets.
TWITTER_API_KEY=

# === Local CLI paths (defaults are usually fine) ===
COUNCIL_DATA_DIR=./data
COUNCIL_USER_CONTEXT_DIR=./user_context
COUNCIL_CONFIG=./config/mentors.yaml

# === MCP server mode (advanced — opt-in only) ===
# The CLI does not need any of this. These settings apply only when
# you run `uvicorn app.main:app` to expose an MCP endpoint.

# Auth mode for the MCP server.
#   "none"  — no auth (only safe behind your own reverse proxy or
#             on localhost)
#   "oauth" — OAuth 2.1 (NOT shipped in council v1; future work)
MCP_AUTH_MODE=none

# Port the FastAPI app binds to. Match this to your reverse proxy.
MCP_PORT=8440

# Public base URL the MCP server advertises in its handshake. Must
# match exactly the scheme + host the MCP client reaches the server
# at, or DNS-rebinding protection rejects the request.
PUBLIC_URL=http://localhost:8440

# Comma-separated allowed Host header values (DNS-rebinding check).
# Add the public host (and any aliases) here.
ALLOWED_HOSTS=localhost,127.0.0.1
